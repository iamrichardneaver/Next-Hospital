/vendor
Homestead.json
Homestead.yaml
Thumbs.db

# Firebase service account (never commit real credentials)
/storage/app/firebase/*.json
!storage/app/firebase/.gitkeep

# ---------------------------------------------------------------------------
# GitHub / public repo safety — never commit secrets, PHI, or prod snapshots
# ---------------------------------------------------------------------------

# All env variants except the sanitized template
.env.*
!.env.example

# Composer auth (may contain GitHub/Private Packagist tokens)
/auth.json

# Private keys & certificates
*.pem
*.p12
*.pfx
id_rsa
id_rsa.*
id_ed25519
id_ed25519.*

# Local SQLite database
/database/database.sqlite
/database/*.sqlite
/database/*.sqlite3

# SQL dumps & backups (may contain patient/staff data)
/storage/app/backups/
/storage/app/demo/
/database/seeders/test_app_version.sql
*.sql.gz
*.sql.bak

# User uploads & runtime media (patient photos, radiology, documents)
/uploads/
/storage/app/uploads/
/storage/app/public/branding/
/storage/app/public/profile_pictures/
/storage/app/public/radiology/
/storage/app/public/uploads/
/storage/app/private/*
!/storage/app/private/.gitignore
/storage/app/temp/
/storage/app/logs/

# Project archives (may bundle .env, vendor, or DB dumps)
*.zip
*.tar
*.tar.gz
*.7z

# PHPUnit cache
.phpunit.result.cache
.phpunit.cache

# Generated seeders are DB snapshots with real users, tokens, sessions & PHI
/database/seeders/Generated/*
!/database/seeders/Generated/README.md
