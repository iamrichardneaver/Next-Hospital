APP_NAME="NextHospital Management System"
APP_ENV=local
# Production (Linux/Plesk): APP_ENV=production blocks migrate:fresh, db:wipe, and migrate:refresh at boot.
APP_KEY=
APP_DEBUG=true
# Must match the URL you use in the browser (include /public for XAMPP subdirectory deploy).
# Local XAMPP example:
#   APP_URL=http://localhost/nexthospital/backend/public
# Production Linux/Plesk examples:
#   Document root = backend/public:  APP_URL=https://your-hospital.com
#   Subdirectory deploy:             APP_URL=https://your-hospital.com/hms/public
# Wrong APP_URL breaks branding logos, favicons, PDF QR codes, and API storage URLs.
APP_URL=http://localhost/nexthospital/backend/public

# Optional CDN or alternate asset base (defaults to APP_URL). Use when static files are on a CDN.
# ASSET_URL=https://cdn.your-hospital.com

# Force HTTPS for generated URLs when behind a TLS-terminating proxy/load balancer.
FORCE_HTTPS=false
TRUSTED_PROXIES=*

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# Database Configuration
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=nexthospital
DB_USERNAME=nexthospital
DB_PASSWORD=your_secure_database_password
# Linux/Plesk: leave DB_SOCKET empty (TCP via DB_HOST). Do not copy macOS/XAMPP socket paths to production.
# Local macOS XAMPP only (uncomment if needed):
# DB_SOCKET=/Applications/XAMPP/xamppfiles/var/mysql/mysql.sock
DB_SOCKET=

# Session Configuration
SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

# Broadcasting Configuration
BROADCAST_DRIVER=pusher
BROADCAST_CONNECTION=pusher

# Pusher Configuration
PUSHER_APP_ID=nexthospital
PUSHER_APP_KEY=nexthospital-key
PUSHER_APP_SECRET=your_pusher_secret
PUSHER_APP_CLUSTER=mt1
PUSHER_HOST=api-mt1.pusher.com
PUSHER_PORT=443
PUSHER_SCHEME=https
PUSHER_USE_TLS=true

# File System Configuration
FILESYSTEM_DISK=local
FILESYSTEM_PUBLIC_DISK=public
FILESYSTEM_CLOUD_DISK=s3

# Queue Configuration
QUEUE_CONNECTION=database
QUEUE_FAILED_DRIVER=database-uuids

# Cache Configuration
CACHE_STORE=database
CACHE_PREFIX=nexthospital_cache_

# Redis Configuration
REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379
REDIS_DB=0
REDIS_CACHE_DB=1
REDIS_QUEUE_CONNECTION=default
REDIS_QUEUE=default
REDIS_QUEUE_RETRY_AFTER=90

# Mail Configuration
MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="info@nexthospital.com"
MAIL_FROM_NAME="${APP_NAME}"

# AWS Configuration
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_URL=
AWS_ENDPOINT=
AWS_USE_PATH_STYLE_ENDPOINT=false

# Vite Configuration
VITE_APP_NAME="${APP_NAME}"
VITE_API_BASE_URL="${APP_URL}/api"
VITE_PUSHER_APP_KEY="${PUSHER_APP_KEY}"
VITE_PUSHER_APP_CLUSTER="${PUSHER_APP_CLUSTER}"
VITE_PUSHER_HOST="${PUSHER_HOST}"
VITE_PUSHER_PORT="${PUSHER_PORT}"
VITE_PUSHER_SCHEME="${PUSHER_SCHEME}"

# Hospital Management System Configuration
HOSPITAL_NAME="NextHospital"
HOSPITAL_ADDRESS="123 Hospital Street, Accra, Ghana"
HOSPITAL_PHONE="+233-123-456-789"
HOSPITAL_EMAIL="info@nexthospital.com"
HOSPITAL_WEBSITE="https://nexthospital.com"

# PDF Configuration
PDF_DRIVER=dompdf
PDF_PAPER_SIZE=A4
PDF_ORIENTATION=portrait

# File Storage Paths (Cross-Platform)
FILES_UPLOAD_PATH=storage/app/uploads
FILES_TEMP_PATH=storage/app/temp
FILES_LOG_PATH=storage/logs
FILES_BACKUP_PATH=storage/app/backups
FILES_PUBLIC_PATH=public
FILES_CACHE_PATH=storage/framework/cache

# Database Paths
DB_PATH=database
DB_BACKUP_PATH=storage/app/backups/database

# URL Configuration
STORAGE_URL=/storage
PUBLIC_URL=/

# PHP extensions (cloud): enable php-gd for PDF logos and radiology image embedding in DomPDF.
# Linux: sudo apt install php-gd && sudo systemctl restart php8.2-fpm apache2

# Security Configuration
SANCTUM_STATEFUL_DOMAINS=localhost:3000,localhost:5173,127.0.0.1:3000,127.0.0.1:5173

# Development Configuration
TELESCOPE_ENABLED=true
DEBUG_BAR_ENABLED=true

# Sync Configuration
SYNC_DRIVER=database
SYNC_BATCH_SIZE=100
SYNC_RETRY_ATTEMPTS=3
SYNC_RETRY_DELAY=5000

# Notification Configuration
NOTIFICATION_DRIVER=database
NOTIFICATION_QUEUE=default

# Lab Configuration
LAB_RESULT_EXPIRY_DAYS=30
LAB_QUALITY_CONTROL_ENABLED=true
LAB_AUTO_VERIFY_NORMAL_RESULTS=false

# Pharmacy Configuration
PHARMACY_LOW_STOCK_THRESHOLD=10
PHARMACY_EXPIRY_WARNING_DAYS=30

# Billing Configuration
BILLING_CURRENCY=GHS
BILLING_TAX_RATE=0.15
BILLING_DISCOUNT_MAX_PERCENT=20

# Insurance Configuration
INSURANCE_CLAIM_TIMEOUT_DAYS=30
INSURANCE_AUTO_VERIFY=false

# Cross-Platform Configuration
CROSS_PLATFORM_ENABLED=true
CROSS_PLATFORM_OS_DETECTION=true
CROSS_PLATFORM_PATH_NORMALIZATION=true

# ---------------------------------------------------------------------------
# Production Linux / Plesk checklist (copy these values into server .env)
# ---------------------------------------------------------------------------
# APP_ENV=production
# APP_DEBUG=false
# APP_KEY=                        # run: php artisan key:generate
# APP_URL=https://your-hospital.com
# FORCE_HTTPS=true
# TRUSTED_PROXIES=*
# DB_HOST=127.0.0.1
# DB_SOCKET=                      # leave empty on Linux
# TELESCOPE_ENABLED=false
# DEBUG_BAR_ENABLED=false
# LOG_LEVEL=warning
# Deploy on server: ./scripts/deploy-linux.sh  (see docs/DEPLOYMENT_CLOUD.md)

# Firebase Cloud Messaging (FCM HTTP v1)
# Download service account JSON from Firebase Console > Project Settings > Service Accounts.
# Place the file outside version control, e.g. storage/app/firebase/service-account.json
FIREBASE_PROJECT_ID=
FIREBASE_CREDENTIALS=storage/app/firebase/service-account.json
